# Development environment — uses MockCryptoAdapter and MockTaxAdapter
# This prevents ERR_CONNECTION_REFUSED when the backend is not running locally.
# To use the real backend, set this to false or remove this file.
VITE_USE_MOCK=true

# Backend API base URL (only used when VITE_USE_MOCK=false)
VITE_API_BASE_URL=http://localhost:8000

# Default Language
VITE_APP_LANG=en
